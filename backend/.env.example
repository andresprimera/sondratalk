MONGO_URI=mongodb://localhost:27017/base-dashboard
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Mail (SMTP / Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="App Name <noreply@example.com>"

# Frontend URL (used for password reset links)
FRONTEND_URL=http://localhost:5173

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

# Google Cloud Storage (when STORAGE_PROVIDER=gcs)
# GCS_BUCKET=my-bucket
# GCS_PROJECT_ID=my-project
# GCS_KEY_FILE=./gcs-key.json
# GCS_SIGNED_URL_EXPIRES=3600

# Firebase Storage (when STORAGE_PROVIDER=firebase)
# FIREBASE_BUCKET=my-bucket.appspot.com
# FIREBASE_KEY_FILE=./firebase-key.json
# FIREBASE_SIGNED_URL_EXPIRES=3600

# Seed Admin (optional — creates default admin on first boot)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123

# AI / LLM (Agent Service)
AI_PROVIDER=openai
AI_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_GENERATIVE_AI_API_KEY=...
